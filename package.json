{
  "name": "parker-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build -w @parker/web",
    "dev:local": "./scripts/bin/dev-local",
    "dev:web": "npm run dev -w @parker/web",
    "test": "go test ./... && npm run typecheck -w @parker/web",
    "typecheck": "npm run typecheck -w @parker/web"
  }
}
