#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
ORIGINAL_PATH="${PATH:-}"
export PATH="$SCRIPT_DIR:$ORIGINAL_PATH"
REPO_NIGIRI_BIN="$REPO_ROOT/tools/bin/nigiri-v0.5.16"

find_real_nigiri() {
  local candidate=""
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    if [[ "$candidate" != "$SCRIPT_DIR/nigiri" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done < <(which -a nigiri 2>/dev/null || true)
  for candidate in /usr/local/bin/nigiri /opt/homebrew/bin/nigiri "$HOME/.nigiri/bin/nigiri"; do
    if [[ -x "$candidate" ]] && [[ "$candidate" != "$SCRIPT_DIR/nigiri" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

if [[ -n "${PARKER_NIGIRI_BIN:-}" ]]; then
  REAL_NIGIRI_BIN="$PARKER_NIGIRI_BIN"
elif [[ -x "$REPO_NIGIRI_BIN" ]]; then
  REAL_NIGIRI_BIN="$REPO_NIGIRI_BIN"
else
  REAL_NIGIRI_BIN=""
fi

if [[ -z "$REAL_NIGIRI_BIN" ]]; then
  if REAL_NIGIRI_BIN="$(find_real_nigiri)"; then
    :
  else
    exec /bin/zsh -lc 'exec nigiri "$@"' -- "$@"
  fi
fi

exec "$REAL_NIGIRI_BIN" "$@"
