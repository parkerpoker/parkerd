#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
JS_ENTRY="$ROOT_DIR/scripts/dev-local.js"
NODE_BIN="${PARKER_NODE_BIN:-/opt/homebrew/bin/node}"

if [[ -x "$NODE_BIN" ]]; then
  exec "$NODE_BIN" "$JS_ENTRY" "$@"
fi

if NODE_BIN="$(command -v node 2>/dev/null)"; then
  exec "$NODE_BIN" "$JS_ENTRY" "$@"
fi

echo "dev-local: node is required. Set PARKER_NODE_BIN or install Node." >&2
exit 1
